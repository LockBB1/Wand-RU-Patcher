{
  "_comment": "Словарь перевода имён читов. Порядок: idioms (точные фразы, верная грамматика) > words (базовое слово + род для согласования) > patterns (adj = прилагательное по роду, либо template = грубый фолбэк) > passthrough. words[x] = {t: перевод (им. падеж), g: род m|f|n|pl}. categories = slug->имя. Новые читы добавлять данными сюда, не в код.",
  "idioms": {
    "god mode": "Режим бога",
    "one-hit kill": "Убийство с одного удара",
    "one hit kill": "Убийство с одного удара",
    "instant kill": "Мгновенное убийство",
    "no reload": "Без перезарядки",
    "no recoil": "Без отдачи",
    "no bounty": "Без розыска",
    "rapid fire": "Скорострельность",
    "super speed": "Суперскорость",
    "super jump": "Супер-прыжок",
    "stealth mode": "Режим невидимости",
    "freeze timer": "Заморозить таймер",
    "unlimited horse health": "Бесконечное здоровье лошади",
    "unlimited horse energy": "Бесконечная энергия лошади"
  },
  "words": {
    "health": { "t": "здоровье", "g": "n" },
    "energy": { "t": "энергия", "g": "f" },
    "focus": { "t": "концентрация", "g": "f" },
    "stamina": { "t": "выносливость", "g": "f" },
    "mana": { "t": "мана", "g": "f" },
    "ammo": { "t": "патроны", "g": "pl" },
    "money": { "t": "деньги", "g": "pl" },
    "items": { "t": "предметы", "g": "pl" },
    "gold": { "t": "золото", "g": "n" },
    "oxygen": { "t": "кислород", "g": "m" },
    "reload": { "t": "перезарядка", "g": "f" },
    "deadeye": { "t": "меткий глаз", "g": "m" }
  },
  "categories": {
    "player": "Игрок",
    "inventory": "Инвентарь",
    "weapons": "Оружие",
    "vehicles": "Транспорт",
    "world": "Мир",
    "gameplay": "Геймплей"
  },
  "patterns": [
    {
      "match": "^(?:unlimited|infinite)\\s+(.+)$",
      "adj": { "m": "Бесконечный", "f": "Бесконечная", "n": "Бесконечное", "pl": "Бесконечные" }
    },
    {
      "match": "^(?:super|mega)\\s+(.+)$",
      "adj": { "m": "Супер", "f": "Супер", "n": "Супер", "pl": "Супер" }
    },
    { "match": "^no\\s+(.+)$", "template": "Без {0}" },
    { "match": "^max(?:imum)?\\s+(.+)$", "template": "Макс. {0}" },
    { "match": "^min(?:imum)?\\s+(.+)$", "template": "Мин. {0}" },
    { "match": "^set\\s+(.+)$", "template": "Задать {0}" },
    { "match": "^add\\s+(.+)$", "template": "Добавить {0}" },
    { "match": "^freeze\\s+(.+)$", "template": "Заморозить {0}" }
  ]
}

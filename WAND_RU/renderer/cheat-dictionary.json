{
  "_comment": "Словарь перевода имён читов. idioms — точные фразы (верная грамматика, высший приоритет). words — базовые слова для хвостов patterns (именительный падеж). patterns — грубый фолбэк для длинного хвоста (муж. род по умолчанию, осознанно неидеальный). Новые читы добавлять данными сюда, не в код.",
  "idioms": {
    "god mode": "Режим бога",
    "one-hit kill": "Убийство с одного удара",
    "one hit kill": "Убийство с одного удара",
    "instant kill": "Мгновенное убийство",
    "no reload": "Без перезарядки",
    "no recoil": "Без отдачи",
    "rapid fire": "Скорострельность",
    "super speed": "Суперскорость",
    "super jump": "Супер-прыжок",
    "stealth mode": "Режим невидимости",
    "freeze timer": "Заморозить таймер",
    "unlimited health": "Бесконечное здоровье",
    "infinite health": "Бесконечное здоровье",
    "unlimited ammo": "Бесконечные патроны",
    "infinite ammo": "Бесконечные патроны",
    "unlimited money": "Бесконечные деньги",
    "infinite money": "Бесконечные деньги",
    "unlimited stamina": "Бесконечная выносливость",
    "infinite stamina": "Бесконечная выносливость"
  },
  "words": {
    "health": "здоровье",
    "ammo": "патроны",
    "money": "деньги",
    "stamina": "выносливость",
    "mana": "мана",
    "gold": "золото",
    "energy": "энергия",
    "oxygen": "кислород",
    "items": "предметы",
    "reload": "перезарядка"
  },
  "patterns": [
    { "match": "^(?:unlimited|infinite)\\s+(.+)$", "template": "Бесконечный {0}" },
    { "match": "^no\\s+(.+)$", "template": "Без {0}" },
    { "match": "^max(?:imum)?\\s+(.+)$", "template": "Макс. {0}" },
    { "match": "^min(?:imum)?\\s+(.+)$", "template": "Мин. {0}" },
    { "match": "^set\\s+(.+)$", "template": "Задать {0}" },
    { "match": "^add\\s+(.+)$", "template": "Добавить {0}" },
    { "match": "^freeze\\s+(.+)$", "template": "Заморозить {0}" },
    { "match": "^(?:super|mega)\\s+(.+)$", "template": "Супер-{0}" }
  ]
}

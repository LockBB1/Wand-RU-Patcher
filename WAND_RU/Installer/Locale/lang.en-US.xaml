<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:s="clr-namespace:System;assembly=mscorlib">

    <s:String x:Key="language_display_name">English</s:String>

    <!-- MainWindow -->
    <s:String x:Key="S_Ready_Sub">Ready to localize</s:String>
    <s:String x:Key="S_Patch">Install Russian</s:String>
    <s:String x:Key="S_PatchLocal">Install Russian (local)</s:String>
    <s:String x:Key="S_PatchOnline">Install Russian (local + internet)</s:String>
    <s:String x:Key="S_PatchOnlineHint">Online mode also translates what the offline dictionary misses (needs internet). You can switch modes in settings.</s:String>
    <s:String x:Key="S_Patched_Title">Russian is installed</s:String>
    <s:String x:Key="S_Restore">Roll back</s:String>
    <s:String x:Key="S_Reinstall">Reinstall</s:String>
    <s:String x:Key="S_NotFound_Title">Wand not found</s:String>
    <s:String x:Key="S_NotFound_Sub">Select the Wand installation folder manually</s:String>
    <s:String x:Key="S_Browse">Browse…</s:String>
    <s:String x:Key="S_Working">Working…</s:String>
    <s:String x:Key="S_Done_Title">Done!</s:String>
    <s:String x:Key="S_Error_Title">Error</s:String>
    <s:String x:Key="S_Retry">Retry</s:String>

    <!-- Settings -->
    <s:String x:Key="S_Settings">Settings</s:String>
    <s:String x:Key="S_WandVersion">Wand version</s:String>
    <s:String x:Key="S_WandFolder">Wand folder</s:String>
    <s:String x:Key="S_RestartWand">Restart Wand after install</s:String>
    <s:String x:Key="S_ShowLog">Show log</s:String>
    <s:String x:Key="S_TranslateCheats">Translate cheat names</s:String>
    <s:String x:Key="S_TranslateOnline">Online translation (needs internet)</s:String>
    <s:String x:Key="S_TranslateOnlineWarn">Translates whatever the offline dictionary misses, over the internet (Google, MyMemory as fallback). If both services are unavailable, some names stay in English. Applies after restarting Wand.</s:String>
    <s:String x:Key="S_OnlineProvider">Translation service</s:String>
    <s:String x:Key="S_Provider_Auto">Auto</s:String>
    <s:String x:Key="S_OnlineProviderInfo">Auto: Google first (better quality), MyMemory when it fails. Google: Google Translate only. MyMemory: MyMemory only - pick it if Google is unreachable on your network. Both services are free and need no keys.</s:String>
    <s:String x:Key="S_ClearCache">Clear cache</s:String>
    <s:String x:Key="S_Close">Close</s:String>
    <s:String x:Key="S_Log">Log</s:String>
    <s:String x:Key="S_CopyLog">Copy</s:String>
    <s:String x:Key="S_ExportLog">Export</s:String>
    <s:String x:Key="S_About">About</s:String>
    <s:String x:Key="S_SourceCode">Source code</s:String>
    <s:String x:Key="S_MadeWith">Made with love by LockBB1</s:String>
    <s:String x:Key="S_StarUs">Star us if WRP helped you &lt;3</s:String>
    <s:String x:Key="S_UpdateAvailable">v{0} available: download</s:String>
    <s:String x:Key="S_MigrateHint">Wand updated to {0}, but the Russian patch is still in {1}. Click "Install Russian" to migrate it to the new version.</s:String>

    <!-- VM messages -->
    <s:String x:Key="S_Msg_NotFound">Wand not found</s:String>
    <s:String x:Key="S_Msg_Done">Done! Restart Wand → Settings → Language → Russian</s:String>
    <s:String x:Key="S_Msg_ErrorPrefix">Error: </s:String>
    <s:String x:Key="S_Msg_WandRunning">Close Wand and try again - it locks the files.</s:String>
    <s:String x:Key="S_Browse_Dialog">Select the Wand installation folder</s:String>

</ResourceDictionary>

<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:s="clr-namespace:System;assembly=mscorlib">

    <s:String x:Key="language_display_name">Русский</s:String>

    <!-- MainWindow -->
    <s:String x:Key="S_Ready_Sub">Готов к русификации</s:String>
    <s:String x:Key="S_Patch">Русифицировать</s:String>
    <s:String x:Key="S_PatchLocal">Русифицировать локально</s:String>
    <s:String x:Key="S_PatchOnline">Русифицировать локально + интернет</s:String>
    <s:String x:Key="S_PatchOnlineHint">Онлайн-режим переводит и то, что не покрыл офлайн-словарь (нужен интернет). Режим можно сменить в настройках.</s:String>
    <s:String x:Key="S_Patched_Title">Русификация установлена</s:String>
    <s:String x:Key="S_Restore">Откатить</s:String>
    <s:String x:Key="S_Reinstall">Переустановить</s:String>
    <s:String x:Key="S_NotFound_Title">Wand не найден</s:String>
    <s:String x:Key="S_NotFound_Sub">Укажите папку установки Wand вручную</s:String>
    <s:String x:Key="S_Browse">Обзор…</s:String>
    <s:String x:Key="S_Working">Работаем…</s:String>
    <s:String x:Key="S_Done_Title">Готово!</s:String>
    <s:String x:Key="S_Error_Title">Ошибка</s:String>
    <s:String x:Key="S_Retry">Повторить</s:String>

    <!-- Settings -->
    <s:String x:Key="S_Settings">Настройки</s:String>
    <s:String x:Key="S_WandVersion">Версия Wand</s:String>
    <s:String x:Key="S_WandFolder">Папка Wand</s:String>
    <s:String x:Key="S_RestartWand">Перезапустить Wand после установки</s:String>
    <s:String x:Key="S_ShowLog">Показывать лог</s:String>
    <s:String x:Key="S_TranslateCheats">Переводить имена читов</s:String>
    <s:String x:Key="S_TranslateOnline">Онлайн-перевод (нужен интернет)</s:String>
    <s:String x:Key="S_TranslateOnlineWarn">Переводит всё, что не покрыл офлайн-словарь, через интернет (Google, при сбое - MyMemory). При недоступности обоих сервисов часть имён останется на английском. Применяется после перезапуска Wand.</s:String>
    <s:String x:Key="S_OnlineProvider">Сервис перевода</s:String>
    <s:String x:Key="S_Provider_Auto">Авто</s:String>
    <s:String x:Key="S_OnlineProviderInfo">Авто: сначала Google (качество выше), при его сбое - MyMemory. Google: только Google Translate. MyMemory: только MyMemory - выбирайте, если Google недоступен в вашей сети. Оба сервиса бесплатны и не требуют ключей.</s:String>
    <s:String x:Key="S_ClearCache">Очистить кэш</s:String>
    <s:String x:Key="S_Close">Закрыть</s:String>
    <s:String x:Key="S_Log">Лог</s:String>
    <s:String x:Key="S_CopyLog">Копировать</s:String>
    <s:String x:Key="S_ExportLog">Экспорт</s:String>
    <s:String x:Key="S_About">О программе</s:String>
    <s:String x:Key="S_SourceCode">Исходный код</s:String>
    <s:String x:Key="S_MadeWith">Сделано с любовью by LockBB1</s:String>
    <s:String x:Key="S_StarUs">Поставьте звезду, если WRP помог вам &lt;3</s:String>
    <s:String x:Key="S_UpdateAvailable">Доступна v{0}: скачать</s:String>
    <s:String x:Key="S_MigrateHint">Wand обновился до {0}, а русификация осталась в {1}. Нажмите «Русифицировать», чтобы перенести её на новую версию.</s:String>

    <!-- VM messages -->
    <s:String x:Key="S_Msg_NotFound">Wand не найден</s:String>
    <s:String x:Key="S_Msg_Done">Готово! Перезапустите Wand → Настройки → Язык → Русский</s:String>
    <s:String x:Key="S_Msg_ErrorPrefix">Ошибка: </s:String>
    <s:String x:Key="S_Msg_WandRunning">Закройте Wand и повторите - он мешает изменить файлы.</s:String>
    <s:String x:Key="S_Browse_Dialog">Выберите папку установки Wand</s:String>

</ResourceDictionary>

<Window x:Class="WandRuInstaller.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:WandRuInstaller.ViewModels"
        d:DataContext="{d:DesignInstance vm:MainVm}"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Wand RU"
        Icon="Assets/logo.png"
        Height="470" Width="700"
        Opacity="0.98"
        Background="Transparent"
        WindowStyle="None"
        ResizeMode="CanMinimize"
        WindowStartupLocation="CenterScreen"
        FontFamily="{StaticResource Inter}"
        AllowsTransparency="True">

    <Border CornerRadius="7" Background="{DynamicResource Background}"
            BorderBrush="{DynamicResource Border}" BorderThickness="1" Margin="10">
        <Border.Effect>
            <DropShadowEffect BlurRadius="15" Direction="-90" RenderingBias="Quality" ShadowDepth="2"/>
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="55"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Header (drag) -->
            <Grid Grid.Row="0" Background="Transparent" MouseLeftButtonDown="OnDragMove">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="25 0 0 0">
                    <Image Source="Assets/logo.png" Width="30" Height="30" VerticalAlignment="Center"/>
                    <TextBlock Foreground="{DynamicResource Foreground}" FontWeight="Bold" Opacity="0.9"
                               VerticalAlignment="Center" FontSize="18" Margin="10 0 0 0" Text="Wand RU"/>
                    <TextBlock x:Name="VersionLabel" VerticalAlignment="Bottom" Opacity="0.6"
                               FontSize="10" Margin="6 0 0 6" Foreground="{DynamicResource Foreground}"/>
                    <!-- Баннер обновления: заполняется из code-behind после тихой проверки GitHub Releases -->
                    <!-- Клик ловим на Down с e.Handled: иначе OnDragMove шапки съедает клик (DragMove) -->
                    <TextBlock x:Name="UpdateBanner" Visibility="Collapsed" VerticalAlignment="Center"
                               FontSize="11" Margin="14 0 0 0" Cursor="Hand" TextDecorations="Underline"
                               Foreground="#4ADE80" MouseLeftButtonDown="OnOpenReleases"/>
                </StackPanel>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <Button Width="25" Height="25" Padding="5" Margin="0 0 6 0"
                            Style="{StaticResource IconButton}" Tag="{StaticResource HeartIcon}"
                            Command="{Binding OpenHelpCommand}"/>
                    <Button Width="25" Height="25" Padding="5" Margin="0 0 6 0"
                            Style="{StaticResource IconButton}" Tag="{StaticResource GitHub}"
                            Command="{Binding OpenAboutCommand}"/>
                    <Button Width="25" Height="25" Padding="5.5" Margin="0 0 6 0"
                            Style="{StaticResource IconButton}" Tag="{StaticResource CogIcon}"
                            Click="OnOpenSettings"/>
                    <Button Width="25" Height="25" Padding="6.5" Margin="0 0 15 0"
                            Style="{StaticResource IconButton}" Tag="{StaticResource CloseIcon}"
                            Click="OnClose"/>
                </StackPanel>
            </Grid>

            <!-- Content -->
            <Grid Grid.Row="1" Margin="30 0 30 25">

                <!-- Ready -->
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center"
                            Visibility="{Binding State, Converter={StaticResource EnumToVisibility}, ConverterParameter=Ready}">
                    <TextBlock Text="{Binding StatusText}" Foreground="{DynamicResource Foreground}"
                               FontSize="16" HorizontalAlignment="Center" Margin="0 0 0 6"/>
                    <TextBlock Text="{DynamicResource S_Ready_Sub}" Foreground="{DynamicResource MutedForeground}"
                               FontSize="12" HorizontalAlignment="Center" Margin="0 0 0 22"/>
                    <!-- Wand обновился, патч в старой версии: пусто = ничего не видно -->
                    <TextBlock Text="{Binding MigrationHint}" Foreground="#FACC15" FontSize="12"
                               HorizontalAlignment="Center" TextWrapping="Wrap" MaxWidth="320"
                               TextAlignment="Center" Margin="0 -12 0 14"/>
                    <Button Content="{DynamicResource S_Patch}" Style="{StaticResource ColoredButton}"
                            Width="280" Height="46" FontSize="16" FontWeight="SemiBold"
                            Command="{Binding OpenPatchOptionsCommand}"/>
                </StackPanel>

                <!-- Patched -->
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center"
                            Visibility="{Binding State, Converter={StaticResource EnumToVisibility}, ConverterParameter=Patched}">
                    <Viewbox Width="46" Height="46" HorizontalAlignment="Center" Margin="0 0 0 12">
                        <Path Fill="{DynamicResource Primary}" Data="{StaticResource CheckDecagram}"/>
                    </Viewbox>
                    <TextBlock Text="{DynamicResource S_Patched_Title}" Foreground="{DynamicResource Foreground}"
                               FontSize="16" HorizontalAlignment="Center" Margin="0 0 0 4"/>
                    <TextBlock Text="{Binding StatusText}" Foreground="{DynamicResource MutedForeground}"
                               FontSize="12" HorizontalAlignment="Center" Margin="0 0 0 22"/>
                    <Button Content="{DynamicResource S_LaunchWand}" Width="310" Height="42" Margin="0 0 0 10"
                            FontWeight="SemiBold" Style="{StaticResource ColoredButton}" Command="{Binding LaunchWandCommand}"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <Button Content="{DynamicResource S_Restore}" Width="150" Height="40" Margin="0 0 10 0"
                                Style="{StaticResource ColoredButton}" Command="{Binding RestoreCommand}"/>
                        <Button Content="{DynamicResource S_Reinstall}" Width="150" Height="40"
                                Style="{StaticResource ColoredButton}" Command="{Binding OpenPatchOptionsCommand}"/>
                    </StackPanel>
                </StackPanel>

                <!-- NotFound -->
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center"
                            Visibility="{Binding State, Converter={StaticResource EnumToVisibility}, ConverterParameter=NotFound}">
                    <Viewbox Width="46" Height="46" HorizontalAlignment="Center" Margin="0 0 0 12">
                        <Path Fill="{DynamicResource MutedForeground}" Data="{StaticResource AlertDecagram}"/>
                    </Viewbox>
                    <TextBlock Text="{DynamicResource S_NotFound_Title}" Foreground="{DynamicResource Foreground}"
                               FontSize="16" HorizontalAlignment="Center" Margin="0 0 0 4"/>
                    <TextBlock Text="{DynamicResource S_NotFound_Sub}" Foreground="{DynamicResource MutedForeground}"
                               FontSize="12" HorizontalAlignment="Center" Margin="0 0 0 22"/>
                    <Button Content="{DynamicResource S_Browse}" Width="200" Height="40"
                            Style="{StaticResource ColoredButton}" Click="OnBrowse"/>
                </StackPanel>

                <!-- Working -->
                <StackPanel VerticalAlignment="Center"
                            Visibility="{Binding State, Converter={StaticResource EnumToVisibility}, ConverterParameter=Working}">
                    <TextBlock Text="{DynamicResource S_Working}" Foreground="{DynamicResource Foreground}"
                               FontSize="15" HorizontalAlignment="Center" Margin="0 0 0 12"/>
                    <ProgressBar IsIndeterminate="True" Height="4" Width="240"
                                 Background="Transparent" Foreground="{DynamicResource Primary}" BorderThickness="0"/>
                </StackPanel>

                <!-- Done -->
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center"
                            Visibility="{Binding State, Converter={StaticResource EnumToVisibility}, ConverterParameter=Done}">
                    <Viewbox Width="54" Height="54" HorizontalAlignment="Center" Margin="0 0 0 14">
                        <Path Fill="{DynamicResource Primary}" Data="{StaticResource CheckDecagram}"/>
                    </Viewbox>
                    <TextBlock Text="{DynamicResource S_Done_Title}" Foreground="{DynamicResource Foreground}"
                               FontSize="18" FontWeight="SemiBold" HorizontalAlignment="Center" Margin="0 0 0 6"/>
                    <TextBlock Text="{Binding StatusText}" Foreground="{DynamicResource MutedForeground}"
                               FontSize="12" TextWrapping="Wrap" TextAlignment="Center" MaxWidth="360"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0 20 0 0">
                        <Button Content="{DynamicResource S_LaunchWand}" Width="170" Height="40" Margin="0 0 10 0"
                                FontWeight="SemiBold" Style="{StaticResource ColoredButton}" Command="{Binding LaunchWandCommand}"/>
                        <Button Content="{DynamicResource S_BackToMenu}" Width="140" Height="40"
                                Style="{StaticResource ColoredButton}" Command="{Binding BackToMenuCommand}"/>
                    </StackPanel>
                </StackPanel>

                <!-- Error -->
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center"
                            Visibility="{Binding State, Converter={StaticResource EnumToVisibility}, ConverterParameter=Error}">
                    <Viewbox Width="50" Height="50" HorizontalAlignment="Center" Margin="0 0 0 12">
                        <Path Fill="{DynamicResource Destructive}" Data="{StaticResource AlertDecagram}"/>
                    </Viewbox>
                    <TextBlock Text="{DynamicResource S_Error_Title}" Foreground="{DynamicResource Foreground}"
                               FontSize="16" HorizontalAlignment="Center" Margin="0 0 0 6"/>
                    <TextBlock Text="{Binding StatusText}" Foreground="{DynamicResource MutedForeground}"
                               FontSize="12" TextWrapping="Wrap" TextAlignment="Center" MaxWidth="380" Margin="0 0 0 18"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <Button Content="{DynamicResource S_Retry}" Width="170" Height="38" Margin="0 0 10 0"
                                Style="{StaticResource ColoredButton}" Command="{Binding PatchCommand}"/>
                        <!-- Патч мог упасть после подмены asar -> Wand кирпич, откат единственный путь назад.
                             Прячем, если манифеста нет (упало до подмены - откатывать нечего). -->
                        <Button Content="{DynamicResource S_Restore}" Width="170" Height="38"
                                Style="{StaticResource ColoredButton}" Command="{Binding RestoreCommand}"
                                Visibility="{Binding RollbackAvailable, Converter={StaticResource ToVisibilityConverter}}"/>
                    </StackPanel>
                </StackPanel>

            </Grid>

            <!-- Log panel (visible when ShowLog) -->
            <Border Grid.Row="2" Height="150" Margin="30 0 30 15"
                    Background="{DynamicResource Card}" CornerRadius="6" Padding="10"
                    Visibility="{Binding Settings.ShowLog, Converter={StaticResource ToVisibilityConverter}, FallbackValue=Collapsed}">
                <DockPanel>
                    <DockPanel DockPanel.Dock="Top" Margin="0 0 0 6">
                        <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                            <Button Content="{DynamicResource S_CopyLog}" Height="22" Padding="10 0" Margin="0 0 6 0"
                                    FontSize="11" Click="OnCopyLog"/>
                            <Button Content="{DynamicResource S_ExportLog}" Height="22" Padding="10 0"
                                    FontSize="11" Click="OnExportLog"/>
                        </StackPanel>
                        <TextBlock Text="{DynamicResource S_Log}" Foreground="{DynamicResource MutedForeground}"
                                   FontSize="11" FontWeight="SemiBold" VerticalAlignment="Center"/>
                    </DockPanel>
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding Log}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding}" Foreground="{DynamicResource MutedForeground}"
                                               FontSize="11" TextWrapping="Wrap"/>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </DockPanel>
            </Border>

            <!-- About overlay -->
            <Border Grid.RowSpan="3" CornerRadius="7" Background="#CC000000"
                    Visibility="{Binding IsAboutOpen, Converter={StaticResource ToVisibilityConverter}}">
                <Border Width="360" Background="{DynamicResource Popover}" CornerRadius="8"
                        BorderBrush="{DynamicResource Border}" BorderThickness="1"
                        VerticalAlignment="Center" HorizontalAlignment="Center" Padding="24">
                    <StackPanel HorizontalAlignment="Center">
                        <Image Source="Assets/logo.png" Width="64" Height="64" Margin="0 0 0 8"/>
                        <TextBlock Text="Wand RU Patcher" Foreground="{DynamicResource PopoverForeground}"
                                   FontSize="16" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                        <TextBlock x:Name="AboutVersion" Foreground="{DynamicResource MutedForeground}"
                                   FontSize="11" HorizontalAlignment="Center" Margin="0 2 0 14"/>
                        <TextBlock Text="{DynamicResource S_MadeWith}" Foreground="{DynamicResource PopoverForeground}"
                                   FontSize="12" HorizontalAlignment="Center" Margin="0 0 0 16"/>
                        <Button Click="OnOpenSource" Height="38" Width="220"
                                Style="{StaticResource ColoredButton}" Margin="0 0 0 12">
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                <Viewbox Width="16" Height="16" Margin="0 0 8 0">
                                    <Path Fill="{DynamicResource PrimaryForeground}" Data="{StaticResource GitHub}"/>
                                </Viewbox>
                                <TextBlock Text="{DynamicResource S_SourceCode}" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                        <TextBlock Text="{DynamicResource S_StarUs}" Foreground="{DynamicResource MutedForeground}"
                                   FontSize="12" HorizontalAlignment="Center" TextAlignment="Center" Margin="0 0 0 18"/>
                        <Button Content="{DynamicResource S_Close}" Style="{StaticResource ColoredButton}"
                                Height="34" Width="120" Command="{Binding CloseAboutCommand}"/>
                    </StackPanel>
                </Border>
            </Border>
            <!-- Help overlay: как помочь проекту -->
            <Border Grid.RowSpan="3" CornerRadius="7" Background="#CC000000"
                    Visibility="{Binding IsHelpOpen, Converter={StaticResource ToVisibilityConverter}}">
                <Border Width="360" Background="{DynamicResource Popover}" CornerRadius="8"
                        BorderBrush="{DynamicResource Border}" BorderThickness="1"
                        VerticalAlignment="Center" HorizontalAlignment="Center" Padding="24">
                    <StackPanel HorizontalAlignment="Center">
                        <Viewbox Width="40" Height="40" Margin="0 0 0 10">
                            <Path Fill="#E25555" Data="{StaticResource HeartIcon}"/>
                        </Viewbox>
                        <TextBlock Text="{DynamicResource S_Help_Title}" Foreground="{DynamicResource PopoverForeground}"
                                   FontSize="16" FontWeight="SemiBold" HorizontalAlignment="Center" Margin="0 0 0 6"/>
                        <TextBlock Text="{DynamicResource S_Help_Sub}" Foreground="{DynamicResource MutedForeground}"
                                   FontSize="12" TextWrapping="Wrap" TextAlignment="Center" Margin="0 0 0 16"/>
                        <Button Content="{DynamicResource S_Help_RequestGame}" Style="{StaticResource ColoredButton}"
                                Height="34" Width="250" Margin="0 0 0 8" Click="OnOpenUrl"
                                Tag="/issues/new?template=game-request.yml"/>
                        <Button Content="{DynamicResource S_Help_ReportBug}" Style="{StaticResource ColoredButton}"
                                Height="34" Width="250" Margin="0 0 0 8" Click="OnOpenUrl"
                                Tag="/issues/new?template=translation-bug.yml"/>
                        <Button Content="{DynamicResource S_Help_Contribute}" Style="{StaticResource ColoredButton}"
                                Height="34" Width="250" Margin="0 0 0 14" Click="OnOpenUrl"
                                Tag="/blob/main/CONTRIBUTING.md"/>
                        <TextBlock Text="{DynamicResource S_StarUs}" Foreground="{DynamicResource MutedForeground}"
                                   FontSize="12" HorizontalAlignment="Center" TextAlignment="Center" Margin="0 0 0 14"/>
                        <Button Content="{DynamicResource S_Close}" Style="{StaticResource ColoredButton}"
                                Height="34" Width="120" Command="{Binding CloseHelpCommand}"/>
                    </StackPanel>
                </Border>
            </Border>
            <!-- Диалог «Что будем русифицировать?»: выбор компонентов перед патчем -->
            <Border Grid.RowSpan="3" CornerRadius="7" Background="#CC000000"
                    Visibility="{Binding IsPatchOptionsOpen, Converter={StaticResource ToVisibilityConverter}}">
                <Border Width="390" Background="{DynamicResource Popover}" CornerRadius="8"
                        BorderBrush="{DynamicResource Border}" BorderThickness="1"
                        VerticalAlignment="Center" HorizontalAlignment="Center" Padding="24">
                    <StackPanel>
                        <TextBlock Text="{DynamicResource S_PatchOptions_Title}" Foreground="{DynamicResource PopoverForeground}"
                                   FontSize="16" FontWeight="SemiBold" HorizontalAlignment="Center" Margin="0 0 0 18"/>
                        <StackPanel Orientation="Horizontal" Margin="0 0 0 11">
                            <CheckBox IsChecked="{Binding Settings.TranslateCheats}" VerticalAlignment="Center"/>
                            <TextBlock Text="{DynamicResource S_Opt_CheatsLocal}" Foreground="{DynamicResource PopoverForeground}"
                                       FontSize="13" Margin="8 0 0 0"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0 0 0 11">
                            <CheckBox IsChecked="{Binding Settings.TranslateCheatsOnline}" VerticalAlignment="Center"/>
                            <TextBlock Text="{DynamicResource S_Opt_CheatsOnline}" Foreground="{DynamicResource PopoverForeground}"
                                       FontSize="13" Margin="8 0 0 0"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0 0 0 11">
                            <CheckBox IsChecked="{Binding Settings.TranslateMaps}" VerticalAlignment="Center"/>
                            <TextBlock Text="{DynamicResource S_Opt_MapsLocal}" Foreground="{DynamicResource PopoverForeground}"
                                       FontSize="13" Margin="8 0 0 0"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0 0 0 11">
                            <CheckBox IsChecked="{Binding Settings.TranslateMapsOnline}" VerticalAlignment="Center"/>
                            <TextBlock Text="{DynamicResource S_Opt_MapsOnline}" Foreground="{DynamicResource PopoverForeground}"
                                       FontSize="13" Margin="8 0 0 0"/>
                        </StackPanel>
                        <TextBlock Text="{DynamicResource S_Opt_MapsHint}" Foreground="{DynamicResource MutedForeground}"
                                   FontSize="11" TextWrapping="Wrap" Margin="24 -4 0 12"/>
                        <StackPanel Orientation="Horizontal" Margin="0 0 0 18">
                            <CheckBox IsChecked="{Binding Settings.RestartWandAfter}" VerticalAlignment="Center"/>
                            <TextBlock Text="{DynamicResource S_Opt_RestartWand}" Foreground="{DynamicResource PopoverForeground}"
                                       FontSize="13" Margin="8 0 0 0"/>
                        </StackPanel>
                        <Button Content="{DynamicResource S_Patch}" Style="{StaticResource ColoredButton}"
                                Height="42" FontWeight="SemiBold" Margin="0 0 0 8" Command="{Binding ConfirmPatchCommand}"/>
                        <Button Content="{DynamicResource S_Close}" Style="{StaticResource ColoredButton}"
                                Height="32" Width="120" HorizontalAlignment="Center" Command="{Binding ClosePatchOptionsCommand}"/>
                    </StackPanel>
                </Border>
            </Border>
            <!-- Бэкап утерян, а Wand уже русифицирован: откат вернуть нечем - решает юзер -->
            <Border Grid.RowSpan="3" CornerRadius="7" Background="#CC000000"
                    Visibility="{Binding IsBackupWarnOpen, Converter={StaticResource ToVisibilityConverter}}">
                <Border Width="390" Background="{DynamicResource Popover}" CornerRadius="8"
                        BorderBrush="{DynamicResource Border}" BorderThickness="1"
                        VerticalAlignment="Center" HorizontalAlignment="Center" Padding="24">
                    <StackPanel>
                        <TextBlock Text="{DynamicResource S_BackupLost_Title}" Foreground="{DynamicResource PopoverForeground}"
                                   FontSize="16" FontWeight="SemiBold" TextWrapping="Wrap"
                                   HorizontalAlignment="Center" TextAlignment="Center" Margin="0 0 0 12"/>
                        <TextBlock Text="{DynamicResource S_BackupLost_Body}" Foreground="{DynamicResource MutedForeground}"
                                   FontSize="13" TextWrapping="Wrap" Margin="0 0 0 18"/>
                        <Button Content="{DynamicResource S_BackupLost_Continue}" Style="{StaticResource ColoredButton}"
                                Height="42" FontWeight="SemiBold" Margin="0 0 0 8"
                                Command="{Binding ConfirmBacklessPatchCommand}"/>
                        <Button Content="{DynamicResource S_Close}" Style="{StaticResource ColoredButton}"
                                Height="32" Width="120" HorizontalAlignment="Center"
                                Command="{Binding CloseBackupWarnCommand}"/>
                    </StackPanel>
                </Border>
            </Border>
        </Grid>
    </Border>
</Window>
